DEFAULT_LLM_PROVIDER=openai
LOCAL_LLM_BASE_URL=
LOCAL_LLM_API_KEY=local
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
MAX_SUBQUESTIONS=4
DEFAULT_RESEARCH_MODE=auto
QUALITY_GATE_THRESHOLD=70
MEMORY_TURNS=3
MEMORY_SUMMARY_ENABLED=true
MEMORY_STORE_FILE=data/memory_store.json
MEMORY_SUMMARY_FILE=data/memory_summary.json
TELEGRAM_WHITELIST_IDS=
TELEGRAM_NOTIFY_CHAT_IDS=
TELEGRAM_PROGRESS_CHAT_IDS=
TELEGRAM_PROGRESS_INTERVAL_SECONDS=10
FORCE_CLEAN=false
WEB_FETCH_TIMEOUT=15
WEB_FETCH_USER_AGENT=Mozilla/5.0 (compatible; WSDeepAgent/1.0)
WEB_FETCH_MAX_CHARS=50000
WEB_FETCH_USE_PLAYWRIGHT=auto
WEB_FETCH_PROXY=
WEB_FETCH_PROXY_LIST=
